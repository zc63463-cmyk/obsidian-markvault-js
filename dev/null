var import_obsidian17 = require("obsidian");
var AddRelationTypeModal = class extends import_obsidian17.Modal {
  existingIds;
  onConfirm;
  idInput = null;
  labelInput = null;
  reverseInput = null;
  isSymmetric = false;
  confirmBtn = null;
  validationMsg = null;
  constructor(app, existingIds, onConfirm) {
    super(app);
    this.existingIds = new Set(existingIds);
    this.onConfirm = onConfirm;
  }
  onOpen() {
    const { contentEl } = this;
    contentEl.empty();
    contentEl.addClass("markvault-add-relation-type");
    contentEl.createEl("h3", {
      text: "Add Custom Relation Type",
      cls: "markvault-add-relation-type-title"
    });
    new import_obsidian17.Setting(contentEl).setName("Type ID").setDesc("Unique identifier (e.g. inspires, contradicts). Letters, numbers, underscores only.").addText((text) => {
      text.setPlaceholder("e.g. inspires");
      this.idInput = text.inputEl;
      text.onChange(() => this._validate());
    });
    new import_obsidian17.Setting(contentEl).setName("Display Label").setDesc("Human-readable label shown in UI (e.g. \u542F\u53D1, \u53CD\u9A73)").addText((text) => {
      text.setPlaceholder("e.g. \u542F\u53D1");
      this.labelInput = text.inputEl;
      text.onChange(() => this._validate());
    });
    new import_obsidian17.Setting(contentEl).setName("Reverse Type ID").setDesc("ID of the reverse relation (e.g. isInspiredBy). Auto-generated from ID if left empty.").addText((text) => {
      text.setPlaceholder("e.g. isInspiredBy (auto: inspiresReverse)");
      this.reverseInput = text.inputEl;
      text.onChange(() => this._validate());
    });
    new import_obsidian17.Setting(contentEl).setName("Symmetric").setDesc("If checked, both directions use the same type (e.g. \u5173\u8054 \u2194 \u5173\u8054)").addToggle((toggle) => {
      toggle.setValue(false);
      toggle.onChange((value) => {
        this.isSymmetric = value;
        if (this.reverseInput) {
          this.reverseInput.disabled = value;
          if (value && this.idInput?.value) {
            this.reverseInput.value = this.idInput.value;
          }
        }
        this._validate();
      });
    });
    this.validationMsg = contentEl.createDiv({
      cls: "markvault-add-relation-type-validation"
    });
    const buttonBar = contentEl.createDiv({ cls: "markvault-add-relation-type-buttons" });
    const cancelBtn = buttonBar.createEl("button", { text: "Cancel" });
    cancelBtn.addEventListener("click", () => this.close());
    this.confirmBtn = buttonBar.createEl("button", {
      text: "Add Type",
      cls: "mod-cta"
    });
    this.confirmBtn.disabled = true;
    this.confirmBtn.addEventListener("click", () => {
      const id2 = this.idInput?.value.trim().replace(/[^a-zA-Z0-9_]/g, "") || "";
      if (!id2) return;
      const isSymmetric = this.isSymmetric;
      const label = this.labelInput?.value.trim() || id2;
      const reverseId = isSymmetric ? id2 : this.reverseInput?.value.trim() || id2 + "Reverse";
      this.onConfirm({ id: id2, label, reverseId, isSymmetric });
      this.close();
    });
  }
  onClose() {
    const { contentEl } = this;
    contentEl.empty();
  }
  _validate() {
    if (!this.idInput || !this.validationMsg || !this.confirmBtn) return;
    const rawId = this.idInput.value.trim();
    const id2 = rawId.replace(/[^a-zA-Z0-9_]/g, "");
    const errors = [];
    if (!rawId) {
      errors.push("Type ID is required");
    } else if (id2 !== rawId) {
      errors.push("Type ID can only contain letters, numbers, and underscores");
    } else if (this.existingIds.has(id2)) {
      errors.push(`Type "${id2}" already exists`);
    }
    if (errors.length > 0) {
      this.validationMsg.textContent = errors[0];
      this.validationMsg.addClass("markvault-validation-error");
      this.validationMsg.removeClass("markvault-validation-ok");
      this.confirmBtn.disabled = true;
    } else {
      this.validationMsg.textContent = rawId ? `\u2713 Will create: ${id2} \u2194 ${this.isSymmetric ? id2 : this.reverseInput?.value.trim() || id2 + "Reverse"}` : "";
      this.validationMsg.removeClass("markvault-validation-error");
      this.validationMsg.addClass("markvault-validation-ok");
      this.confirmBtn.disabled = !rawId;
    }
  }
};

